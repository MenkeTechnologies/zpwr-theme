  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#b95e0a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "comment.line.shebang",
        "comment.line.shebang.stryke"
      ],
      "settings": {
        "foreground": "#92400e",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted.double",
        "string.quoted.single",
        "string.quoted.other"
      ],
      "settings": {
        "foreground": "#84cc16"
      }
    },
    {
      "scope": [
        "string.interpolated",
        "string.interpolated.backtick",
        "string.unquoted.heredoc"
      ],
      "settings": {
        "foreground": "#9ad540"
      }
    },
    {
      "scope": [
        "string.regexp",
        "string.regexp.stryke"
      ],
      "settings": {
        "foreground": "#ea580c"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#f97316"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.numeric.stryke"
      ],
      "settings": {
        "foreground": "#f97316"
      }
    },
    {
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.magic"
      ],
      "settings": {
        "foreground": "#f97316"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other.phase",
        "storage.type.control"
      ],
      "settings": {
        "foreground": "#f59e0b"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.word"
      ],
      "settings": {
        "foreground": "#fb923c"
      }
    },
    {
      "scope": [
        "keyword.operator.thread",
        "keyword.other.concurrent",
        "support.function.parallel"
      ],
      "settings": {
        "foreground": "#ea580c",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "keyword.operator.heredoc"
      ],
      "settings": {
        "foreground": "#d97706"
      }
    },
    {
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#f59e0b"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "support.function.builtin"
      ],
      "settings": {
        "foreground": "#fb923c"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#fde047"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.tag.stryke"
      ],
      "settings": {
        "foreground": "#f59e0b"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#fde047"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.scalar",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#fef3c7"
      }
    },
    {
      "scope": [
        "variable.other.array",
        "variable.other.hash"
      ],
      "settings": {
        "foreground": "#f3ce8d"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.special",
        "variable.language.this",
        "constant.language.stryke"
      ],
      "settings": {
        "foreground": "#ea580c",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "variable.other.interpolated",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#fcad6d"
      }
    },
    {
      "scope": [
        "punctuation.definition.variable",
        "sign",
        "sign.stryke",
        "punctuation.definition.sigil"
      ],
      "settings": {
        "foreground": "#ea580c"
      }
    },
    {
      "scope": [
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#fb923c"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name"
      ],
      "settings": {
        "foreground": "#fb923c",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#f59e0b",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#ea580c",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#84cc16"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#fb923c",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#dc2626",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#d97706"
      }
    }
  ]
}
