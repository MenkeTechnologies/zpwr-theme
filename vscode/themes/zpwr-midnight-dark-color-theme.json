  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#718094",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "comment.line.shebang",
        "comment.line.shebang.stryke"
      ],
      "settings": {
        "foreground": "#475569",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted.double",
        "string.quoted.single",
        "string.quoted.other"
      ],
      "settings": {
        "foreground": "#34d399"
      }
    },
    {
      "scope": [
        "string.interpolated",
        "string.interpolated.backtick",
        "string.unquoted.heredoc"
      ],
      "settings": {
        "foreground": "#59dbab"
      }
    },
    {
      "scope": [
        "string.regexp",
        "string.regexp.stryke"
      ],
      "settings": {
        "foreground": "#6366f1"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#818cf8"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.numeric.stryke"
      ],
      "settings": {
        "foreground": "#818cf8"
      }
    },
    {
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.magic"
      ],
      "settings": {
        "foreground": "#818cf8"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other.phase",
        "storage.type.control"
      ],
      "settings": {
        "foreground": "#7c3aed"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.word"
      ],
      "settings": {
        "foreground": "#38bdf8"
      }
    },
    {
      "scope": [
        "keyword.operator.thread",
        "keyword.other.concurrent",
        "support.function.parallel"
      ],
      "settings": {
        "foreground": "#6366f1",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "keyword.operator.heredoc"
      ],
      "settings": {
        "foreground": "#94a3b8"
      }
    },
    {
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7c3aed"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "support.function.builtin"
      ],
      "settings": {
        "foreground": "#38bdf8"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#c084fc"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.tag.stryke"
      ],
      "settings": {
        "foreground": "#7c3aed"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#c084fc"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.scalar",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#e0e7ff"
      }
    },
    {
      "scope": [
        "variable.other.array",
        "variable.other.hash"
      ],
      "settings": {
        "foreground": "#c9d3ea"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.special",
        "variable.language.this",
        "constant.language.stryke"
      ],
      "settings": {
        "foreground": "#6366f1",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "variable.other.interpolated",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#6acefa"
      }
    },
    {
      "scope": [
        "punctuation.definition.variable",
        "sign",
        "sign.stryke",
        "punctuation.definition.sigil"
      ],
      "settings": {
        "foreground": "#6366f1"
      }
    },
    {
      "scope": [
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#38bdf8"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name"
      ],
      "settings": {
        "foreground": "#38bdf8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#7c3aed",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#6366f1",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#34d399"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#38bdf8",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#f472b6",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#94a3b8"
      }
    }
  ]
}
