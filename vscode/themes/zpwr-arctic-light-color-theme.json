  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#0e7490",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "comment.line.shebang",
        "comment.line.shebang.stryke"
      ],
      "settings": {
        "foreground": "#a5f3fc",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted.double",
        "string.quoted.single",
        "string.quoted.other"
      ],
      "settings": {
        "foreground": "#0d9488"
      }
    },
    {
      "scope": [
        "string.interpolated",
        "string.interpolated.backtick",
        "string.unquoted.heredoc"
      ],
      "settings": {
        "foreground": "#39a79d"
      }
    },
    {
      "scope": [
        "string.regexp",
        "string.regexp.stryke"
      ],
      "settings": {
        "foreground": "#0e7490"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#06b6d4"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.numeric.stryke"
      ],
      "settings": {
        "foreground": "#06b6d4"
      }
    },
    {
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.magic"
      ],
      "settings": {
        "foreground": "#06b6d4"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other.phase",
        "storage.type.control"
      ],
      "settings": {
        "foreground": "#0284c7"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.word"
      ],
      "settings": {
        "foreground": "#0891b2"
      }
    },
    {
      "scope": [
        "keyword.operator.thread",
        "keyword.other.concurrent",
        "support.function.parallel"
      ],
      "settings": {
        "foreground": "#0e7490",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "keyword.operator.heredoc"
      ],
      "settings": {
        "foreground": "#0e7490"
      }
    },
    {
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#0284c7"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "support.function.builtin"
      ],
      "settings": {
        "foreground": "#0891b2"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#155e75"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.tag.stryke"
      ],
      "settings": {
        "foreground": "#0284c7"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#155e75"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.scalar",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#164e63"
      }
    },
    {
      "scope": [
        "variable.other.array",
        "variable.other.hash"
      ],
      "settings": {
        "foreground": "#145971"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.special",
        "variable.language.this",
        "constant.language.stryke"
      ],
      "settings": {
        "foreground": "#0e7490",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "variable.other.interpolated",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#46adc5"
      }
    },
    {
      "scope": [
        "punctuation.definition.variable",
        "sign",
        "sign.stryke",
        "punctuation.definition.sigil"
      ],
      "settings": {
        "foreground": "#0e7490"
      }
    },
    {
      "scope": [
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#0891b2"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name"
      ],
      "settings": {
        "foreground": "#0891b2",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#0284c7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#0e7490",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#0d9488"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#0891b2",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#e11d48",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#0e7490"
      }
    }
  ]
}
