  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#5f708c",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "comment.line.shebang",
        "comment.line.shebang.stryke"
      ],
      "settings": {
        "foreground": "#3d4f6a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted.double",
        "string.quoted.single",
        "string.quoted.other"
      ],
      "settings": {
        "foreground": "#39ff14"
      }
    },
    {
      "scope": [
        "string.interpolated",
        "string.interpolated.backtick",
        "string.unquoted.heredoc"
      ],
      "settings": {
        "foreground": "#5dff3e"
      }
    },
    {
      "scope": [
        "string.regexp",
        "string.regexp.stryke"
      ],
      "settings": {
        "foreground": "#d300c5"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#ff6b35"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.numeric.stryke"
      ],
      "settings": {
        "foreground": "#ff6b35"
      }
    },
    {
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.magic"
      ],
      "settings": {
        "foreground": "#ff6b35"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other.phase",
        "storage.type.control"
      ],
      "settings": {
        "foreground": "#ff2a6d"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.word"
      ],
      "settings": {
        "foreground": "#05d9e8"
      }
    },
    {
      "scope": [
        "keyword.operator.thread",
        "keyword.other.concurrent",
        "support.function.parallel"
      ],
      "settings": {
        "foreground": "#d300c5",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "keyword.operator.heredoc"
      ],
      "settings": {
        "foreground": "#7a8ba8"
      }
    },
    {
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff2a6d"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "support.function.builtin"
      ],
      "settings": {
        "foreground": "#05d9e8"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#f9f002"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.tag.stryke"
      ],
      "settings": {
        "foreground": "#ff2a6d"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#f9f002"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.scalar",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#e0f0ff"
      }
    },
    {
      "scope": [
        "variable.other.array",
        "variable.other.hash"
      ],
      "settings": {
        "foreground": "#c1d2e5"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.special",
        "variable.language.this",
        "constant.language.stryke"
      ],
      "settings": {
        "foreground": "#d300c5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "variable.other.interpolated",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#44e3ee"
      }
    },
    {
      "scope": [
        "punctuation.definition.variable",
        "sign",
        "sign.stryke",
        "punctuation.definition.sigil"
      ],
      "settings": {
        "foreground": "#d300c5"
      }
    },
    {
      "scope": [
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#05d9e8"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name"
      ],
      "settings": {
        "foreground": "#05d9e8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#ff2a6d",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#d300c5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#39ff14"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#05d9e8",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ff073a",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#7a8ba8"
      }
    }
  ]
}
