  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#4338ca",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "comment.line.shebang",
        "comment.line.shebang.stryke"
      ],
      "settings": {
        "foreground": "#a5b4fc",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted.double",
        "string.quoted.single",
        "string.quoted.other"
      ],
      "settings": {
        "foreground": "#059669"
      }
    },
    {
      "scope": [
        "string.interpolated",
        "string.interpolated.backtick",
        "string.unquoted.heredoc"
      ],
      "settings": {
        "foreground": "#32a984"
      }
    },
    {
      "scope": [
        "string.regexp",
        "string.regexp.stryke"
      ],
      "settings": {
        "foreground": "#4f46e5"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#6366f1"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.numeric.stryke"
      ],
      "settings": {
        "foreground": "#6366f1"
      }
    },
    {
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.magic"
      ],
      "settings": {
        "foreground": "#6366f1"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other.phase",
        "storage.type.control"
      ],
      "settings": {
        "foreground": "#6d28d9"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.word"
      ],
      "settings": {
        "foreground": "#0284c7"
      }
    },
    {
      "scope": [
        "keyword.operator.thread",
        "keyword.other.concurrent",
        "support.function.parallel"
      ],
      "settings": {
        "foreground": "#4f46e5",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "keyword.operator.heredoc"
      ],
      "settings": {
        "foreground": "#4338ca"
      }
    },
    {
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#6d28d9"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "support.function.builtin"
      ],
      "settings": {
        "foreground": "#0284c7"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#7c3aed"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.tag.stryke"
      ],
      "settings": {
        "foreground": "#6d28d9"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#7c3aed"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.scalar",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#1e1b4b"
      }
    },
    {
      "scope": [
        "variable.other.array",
        "variable.other.hash"
      ],
      "settings": {
        "foreground": "#292471"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.special",
        "variable.language.this",
        "constant.language.stryke"
      ],
      "settings": {
        "foreground": "#4f46e5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "variable.other.interpolated",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#41a3d5"
      }
    },
    {
      "scope": [
        "punctuation.definition.variable",
        "sign",
        "sign.stryke",
        "punctuation.definition.sigil"
      ],
      "settings": {
        "foreground": "#4f46e5"
      }
    },
    {
      "scope": [
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#0284c7"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name"
      ],
      "settings": {
        "foreground": "#0284c7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#6d28d9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#4f46e5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#059669"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#0284c7",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#e11d48",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#4338ca"
      }
    }
  ]
}
