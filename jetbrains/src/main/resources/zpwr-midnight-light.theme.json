      "underlinedTabForeground": "text",
      "underlineColor": "cyan",
      "inactiveUnderlineColor": "textDim",
      "hoverBackground": "hover"
    },
    "EditorTabs": {
      "background": "ink",
      "underlinedTabBackground": "ink",
      "underlinedTabForeground": "text",
      "underlineColor": "cyan",
      "inactiveColoredFileBackground": "panel",
      "hoverBackground": "hover",
      "borderColor": "border"
    },
    "StatusBar": {
      "background": "ink",
      "borderColor": "border",
