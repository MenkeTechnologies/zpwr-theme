{
  "name": "ZPWR Midnight Light",
  "author": "MenkeTechnologies",
  "dark": false,
  "editorScheme": "/zpwr-midnight-light.xml",
  "colors": {
    "ink": "#eef2ff",
    "panel": "#e0e7ff",
    "card": "#ffffff",
    "hover": "#f5f3ff",
    "border": "#c7d2fe",
    "cyan": "#0284c7",
    "cyanBright": "#41a3d5",
    "pink": "#6d28d9",
    "magenta": "#4f46e5",
    "green": "#059669",
    "orange": "#6366f1",
    "yellow": "#7c3aed",
    "text": "#1e1b4b",
    "textSoft": "#292471",
    "textDim": "#4338ca",
    "muted": "#a5b4fc"
