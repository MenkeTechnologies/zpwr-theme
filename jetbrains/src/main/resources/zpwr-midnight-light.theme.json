      "focusedBorderColor": "cyan",
      "default": {
        "startBackground": "cyan",
        "endBackground": "cyan",
        "foreground": "ink",
        "startBorderColor": "cyan",
        "endBorderColor": "cyan",
        "focusColor": "cyanBright"
      }
    },
    "Component": {
      "focusColor": "cyan",
