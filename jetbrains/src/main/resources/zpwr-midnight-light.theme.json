    "NavBar": {
      "borderColor": "border"
    },
    "ScrollBar": {
      "thumbColor": "#c7d2fe80",
      "hoverThumbColor": "#0284c740"
    },
    "TitlePane": {
      "background": "ink",
      "borderColor": "border",
      "inactiveBackground": "ink"
    },
    "MainToolbar": {
      "background": "ink",
      "Icon": {
        "hoverBackground": "hover"
      },
      "Dropdown": {
        "hoverBackground": "hover"
      }
    },
    "ActionButton": {
      "hoverBackground": "hover",
      "hoverBorderColor": "border",
      "pressedBackground": "card"
    },
    "Notification": {
      "background": "card",
      "borderColor": "border",
      "errorBackground": "#e11d4822",
      "errorBorderColor": "pink"
    },
    "Tooltip": {
      "background": "card",
      "borderColor": "border"
    },
    "Counter": {
      "background": "pink",
      "foreground": "ink"
    }
  },
  "icons": {
    "ColorPalette": {
      "Actions.Blue": "#0284c7",
      "Actions.Green": "#059669",
      "Actions.Red": "#e11d48",
      "Actions.Yellow": "#7c3aed",
      "Actions.Grey": "#4338ca",
      "Objects.Blue": "#0284c7",
      "Objects.Green": "#059669",
      "Objects.Pink": "#6d28d9",
      "Objects.Purple": "#4f46e5",
      "Objects.Red": "#e11d48",
      "Objects.Yellow": "#7c3aed",
      "Objects.Grey": "#4338ca"
    }
  }
