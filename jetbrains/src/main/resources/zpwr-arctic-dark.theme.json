{
  "name": "ZPWR Arctic",
  "author": "MenkeTechnologies",
  "dark": true,
  "editorScheme": "/zpwr-arctic-dark.xml",
  "colors": {
    "ink": "#020a0e",
    "panel": "#041218",
    "card": "#061a22",
    "hover": "#0a2430",
    "border": "#1a3a4e",
    "cyan": "#67e8f9",
    "cyanBright": "#8deefb",
    "pink": "#0ea5e9",
    "magenta": "#06b6d4",
    "green": "#2dd4bf",
    "orange": "#22d3ee",
    "yellow": "#a5f3fc",
    "text": "#ecfeff",
    "textSoft": "#d7fbfe",
    "textDim": "#a5f3fc",
    "muted": "#155e75"
  },
  "ui": {
    "*": {
      "background": "panel",
      "foreground": "text",
      "infoForeground": "textDim",
      "disabledBackground": "ink",
      "disabledForeground": "muted",
      "disabledText": "muted",
      "inactiveForeground": "textDim",
      "selectionBackground": "hover",
      "selectionForeground": "cyan",
      "selectionInactiveBackground": "card",
      "selectionInactiveForeground": "text",
      "borderColor": "border",
