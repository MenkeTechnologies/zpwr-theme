    "DefaultTabs": {
      "background": "ink",
      "borderColor": "border",
      "underlinedTabBackground": "panel",
      "underlinedTabForeground": "text",
      "underlineColor": "cyan",
      "inactiveUnderlineColor": "textDim",
      "hoverBackground": "hover"
    },
    "EditorTabs": {
      "background": "ink",
      "underlinedTabBackground": "ink",
      "underlinedTabForeground": "text",
      "underlineColor": "cyan",
      "inactiveColoredFileBackground": "panel",
      "hoverBackground": "hover",
      "borderColor": "border"
    },
    "StatusBar": {
      "background": "ink",
      "borderColor": "border",
      "hoverBackground": "hover"
    },
    "NavBar": {
      "borderColor": "border"
    },
    "ScrollBar": {
      "thumbColor": "#1a3a4e80",
      "hoverThumbColor": "#67e8f940"
    },
    "TitlePane": {
      "background": "ink",
      "borderColor": "border",
      "inactiveBackground": "ink"
    },
    "MainToolbar": {
      "background": "ink",
      "Icon": {
        "hoverBackground": "hover"
      },
      "Dropdown": {
        "hoverBackground": "hover"
      }
    },
    "ActionButton": {
      "hoverBackground": "hover",
      "hoverBorderColor": "border",
      "pressedBackground": "card"
    },
    "Notification": {
      "background": "card",
      "borderColor": "border",
      "errorBackground": "#f43f5e22",
      "errorBorderColor": "pink"
    },
    "Tooltip": {
      "background": "card",
      "borderColor": "border"
    },
    "Counter": {
      "background": "pink",
      "foreground": "ink"
    }
  },
  "icons": {
    "ColorPalette": {
      "Actions.Blue": "#67e8f9",
      "Actions.Green": "#2dd4bf",
      "Actions.Red": "#f43f5e",
      "Actions.Yellow": "#a5f3fc",
      "Actions.Grey": "#a5f3fc",
      "Objects.Blue": "#67e8f9",
      "Objects.Green": "#2dd4bf",
      "Objects.Pink": "#0ea5e9",
      "Objects.Purple": "#06b6d4",
      "Objects.Red": "#f43f5e",
      "Objects.Yellow": "#a5f3fc",
      "Objects.Grey": "#a5f3fc"
    }
  }
}
