      "focusColor": "cyan",
      "focusedBorderColor": "cyan",
      "errorForeground": "pink",
      "acceleratorForeground": "cyan"
    },
    "Editor": {
      "background": "ink",
      "shortcutForeground": "cyan"
    },
    "Panel": {
